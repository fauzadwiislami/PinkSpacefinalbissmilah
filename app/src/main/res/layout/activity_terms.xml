<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_soft_gradient"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Terms &amp; Conditions"
        android:textColor="@color/pink_dark"
        android:textSize="26sp"
        android:textStyle="bold" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Please read carefully before creating your account."
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/termsScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card"
        android:fillViewport="true"
        android:overScrollMode="always"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/txtTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="8dp"
            android:padding="20dp"
            android:text="@string/terms_conditions_text"
            android:textColor="@color/pink_dark"
            android:textSize="14sp" />

    </androidx.core.widget.NestedScrollView>


    <CheckBox
        android:id="@+id/checkAgree"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:enabled="true"
        android:text="Saya setuju dengan Terms and Conditions"
        android:textColor="@color/pink_dark"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateAccount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:enabled="false"
        android:text="Create Account"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@color/pink_primary"
        app:cornerRadius="24dp" />

</LinearLayout>